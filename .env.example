# คัดลอกไฟล์นี้เป็น .env แล้วเติมค่าจริง
# (อย่า commit .env ลง git — มันอยู่ใน .gitignore แล้ว)

# Server
NODE_ENV=production
PORT=3000

# Session
SESSION_SECRET=เปลี่ยนเป็น_random_string_ยาวๆ_อย่างน้อย_32_ตัว

# CORS (ถ้าใช้ domain เดียวปล่อยว่างได้)
# CORS_ORIGIN=https://yourdomain.com

# MySQL (HostAtom)
DB_HOST=localhost
DB_PORT=3306
DB_USER=vpkann_database
DB_PASSWORD=
DB_NAME=vpkann_database
DB_POOL_LIMIT=10
